# ── API ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://bills:bills_secret@localhost:5432/bills_db"

REDIS_URL="redis://:redis_secret@localhost:6379"

JWT_SECRET="change-me-to-a-very-long-random-string-in-production"

# ── Docker Compose (used only in docker-compose.yml) ─────────────────
POSTGRES_USER=bills
POSTGRES_PASSWORD=bills_secret
POSTGRES_DB=bills_db
REDIS_PASSWORD=redis_secret

# ── Optional ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
